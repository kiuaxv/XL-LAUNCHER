<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.XLauncher" parent="Theme.MaterialComponents.DayNight">
        <item name="colorPrimary">@color/primary_gold</item>
        <item name="colorPrimaryVariant">@color/primary_gold_dark</item>
        <item name="colorSecondary">@color/accent_cyan</item>
        <item name="colorSecondaryVariant">@color/accent_cyan</item>
        <item name="colorError">@color/error</item>
        <item name="android:colorBackground">@color/background_dark</item>
        <item name="android:textColorPrimary">@color/text_primary</item>
        <item name="android:textColorSecondary">@color/text_secondary</item>
        <item name="android:windowBackground">@color/background_dark</item>
    </style>

    <style name="Theme.XLauncher.NoActionBar">
        <item name="windowNoTitle">true</item>
        <item name="windowActionBar">false</item>
        <item name="android:windowFullscreen">false</item>
        <item name="android:windowDrawsSystemBarBackgrounds">true</item>
        <item name="android:statusBarColor">@color/background_dark</item>
        <item name="android:navigationBarColor">@color/background_dark</item>
    </style>

    <style name="GoldenButton" parent="Widget.MaterialComponents.Button">
        <item name="backgroundTint">@color/primary_gold</item>
        <item name="android:textColor">@color/background_dark</item>
        <item name="android:textStyle">bold</item>
        <item name="cornerRadius">12dp</item>
    </style>

    <style name="GoldenOutlinedButton" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="strokeColor">@color/primary_gold</item>
        <item name="android:textColor">@color/primary_gold</item>
    </style>
</resources>
