<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_dark"
    android:orientation="vertical">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/background_darker"
        android:orientation="horizontal"
        android:padding="16dp">

        <ImageView
            android:id="@+id/logo"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:contentDescription="@string/app_name"
            android:src="@drawable/ic_launcher" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center_vertical"
            android:paddingStart="16dp"
            android:text="@string/app_name"
            android:textColor="@color/primary_gold"
            android:textSize="24sp"
            android:textStyle="bold" />

        <ImageView
            android:id="@+id/menu_button"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:contentDescription="Menu"
            android:src="@drawable/ic_menu" />

    </LinearLayout>

    <!-- Main Content -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="horizontal"
        android:padding="16dp">

        <!-- Left Robot (XAI Assistant) -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="0.35"
            android:gravity="bottom|center_horizontal"
            android:orientation="vertical">

            <ImageView
                android:id="@+id/xai_robot"
                android:layout_width="100dp"
                android:layout_height="120dp"
                android:contentDescription="XAI Robot"
                android:src="@drawable/ic_robot_xai" />

        </LinearLayout>

        <!-- Center Logo -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="0.3"
            android:gravity="center"
            android:orientation="vertical">

            <ImageView
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:contentDescription="X Logo"
                android:src="@drawable/ic_x_logo" />

        </LinearLayout>

        <!-- Right Card -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="0.35"
            android:orientation="vertical">

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_marginStart="8dp"
                android:layout_marginEnd="0dp"
                app:cardBackgroundColor="@color/primary_gold_light"
                app:cardCornerRadius="20dp"
                app:cardElevation="8dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center_horizontal"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <!-- Profile Section -->
                    <LinearLayout
                        android:id="@+id/profile_section"
                        android:layout_width="match_parent"
                        android:layout_height="80dp"
                        android:gravity="center_horizontal"
                        android:orientation="vertical">

                        <ImageView
                            android:id="@+id/profile_picture"
                            android:layout_width="60dp"
                            android:layout_height="60dp"
                            android:contentDescription="Profile"
                            android:src="@drawable/ic_profile" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="@string/profile"
                            android:textColor="@color/background_dark"
                            android:textSize="12sp" />

                    </LinearLayout>

                    <!-- Edit Profile Button -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/edit_profile_btn"
                        android:layout_width="match_parent"
                        android:layout_height="36dp"
                        android:layout_marginVertical="4dp"
                        android:text="@string/edit_profile"
                        android:textSize="10sp"
                        app:backgroundTint="@color/background_dark"
                        app:cornerRadius="8dp" />

                    <!-- Version -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="40dp"
                        android:layout_marginVertical="4dp"
                        android:background="@drawable/rounded_button_bg"
                        android:gravity="center"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/version"
                            android:textColor="@color/background_dark"
                            android:textSize="10sp" />

                        <TextView
                            android:id="@+id/version_number"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="1.0"
                            android:textColor="@color/background_dark"
                            android:textSize="14sp"
                            android:textStyle="bold" />

                    </LinearLayout>

                    <!-- Play Button -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/play_btn"
                        android:layout_width="match_parent"
                        android:layout_height="44dp"
                        android:layout_marginVertical="4dp"
                        android:text="@string/play"
                        android:textSize="14sp"
                        app:backgroundTint="@color/background_dark"
                        app:cornerRadius="10dp" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>

    </LinearLayout>

</LinearLayout>
