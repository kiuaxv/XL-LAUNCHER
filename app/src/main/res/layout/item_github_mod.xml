<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="8dp"
    app:cardBackgroundColor="@color/background_darker"
    app:cardCornerRadius="12dp"
    app:cardElevation="4dp"
    app:strokeColor="@color/accent_cyan"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="12dp">

        <!-- Mod Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/github_mod_name"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Mod Name"
                    android:textColor="@color/primary_gold"
                    android:textSize="@dimen/text_size_large"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/github_mod_author"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="by Author"
                    android:textColor="@color/accent_cyan"
                    android:textSize="@dimen/text_size_small" />

            </LinearLayout>

        </LinearLayout>

        <!-- Description -->
        <TextView
            android:id="@+id/github_mod_description"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginVertical="8dp"
            android:maxLines="2"
            android:text="Mod description"
            android:textColor="@color/text_secondary"
            android:textSize="@dimen/text_size_small" />

        <!-- Stats -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/github_mod_stars"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="⭐ 0"
                android:textColor="@color/primary_gold"
                android:textSize="@dimen/text_size_small" />

            <TextView
                android:id="@+id/github_mod_downloads"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="📥 0"
                android:textColor="@color/primary_gold"
                android:textSize="@dimen/text_size_small" />

        </LinearLayout>

        <!-- Publish Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/publish_to_store_btn"
            android:layout_width="match_parent"
            android:layout_height="36dp"
            android:text="Publish to Smart Store"
            android:textSize="12sp"
            app:backgroundTint="@color/accent_cyan"
            app:cornerRadius="6dp" />

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
