<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_dark"
    android:orientation="vertical"
    android:padding="16dp">

    <!-- Header -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingBottom="16dp"
        android:text="GitHub Login"
        android:textColor="@color/primary_gold"
        android:textSize="24sp"
        android:textStyle="bold" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingBottom="16dp"
        android:text="Enter your GitHub Personal Access Token"
        android:textColor="@color/text_secondary"
        android:textSize="14sp" />

    <!-- Token Input -->
    <com.google.android.material.textfield.TextInputLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp"
        app:boxBackgroundColor="@color/background_darker"
        app:boxCornerRadiusBottomEnd="8dp"
        app:boxCornerRadiusBottomStart="8dp"
        app:boxCornerRadiusTopEnd="8dp"
        app:boxCornerRadiusTopStart="8dp"
        app:boxStrokeColor="@color/primary_gold">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/github_token_input"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="ghp_xxxxxxxxxxxxxxxxxxxx"
            android:inputType="textPassword"
            android:textColor="@color/text_primary" />

    </com.google.android.material.textfield.TextInputLayout>

    <!-- Info Text -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingBottom="16dp"
        android:text="To get a token: GitHub Settings → Developer settings → Personal access tokens → Generate new token"
        android:textColor="@color/text_secondary"
        android:textSize="12sp" />

    <!-- Login Button -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/github_login_btn"
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:layout_marginBottom="12dp"
        android:text="Login with GitHub"
        app:backgroundTint="@color/primary_gold"
        app:cornerRadius="8dp" />

    <!-- Back Button -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/back_button"
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:text="Back"
        app:backgroundTint="@color/background_darker"
        app:cornerRadius="8dp"
        app:strokeColor="@color/primary_gold"
        app:strokeWidth="2dp" />

</LinearLayout>
